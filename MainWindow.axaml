<Window xmlns="https://github.com/avaloniaui" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        x:Class="MyApp.MainWindow" 
        Width="900" 
        Height="500" 
        Title="Bank Account Manager"> 
 
    <Grid> 
 
        <Border Width="800" 
                Padding="15" 
                Background="White" 
                BorderBrush="Gray" 
                BorderThickness="1" 
                CornerRadius="8" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"> 
 
            <Grid ColumnDefinitions="220,*"> 
 
                <!-- LEFT PANEL --> 
                <StackPanel Grid.Column="0" Spacing="10"> 
 
                    <TextBlock Text="Owner Name"/> 
                    <TextBox Name="OwnerTextBox" Width="180"/> 

                    <TextBlock Text="Interest rate%"/> 
                    <TextBox Name="InterestRateTextBox" Width="100"/> 

                    <Button Content="Create Account" 
                            Width="180" 
                            Click="CreateAccountBtn_Click"/> 
 
                    <TextBlock Text="Amount"/> 
                    <TextBox Name="AmountNum" Width="180"/> 
 
                </StackPanel> 
 
                <!-- RIGHT PANEL --> 
                <Grid Grid.Column="1" 
                      RowDefinitions="Auto,*,Auto" 
                      Margin="10,0,0,0"> 
 
                    <!-- TABLE HEADER --> 
                    <Border Grid.Row="0" 
                            Background="#EEEEEE" 
                            Padding="8" 
                            BorderBrush="Gray" 
                            BorderThickness="1"> 
 
                        <Grid ColumnDefinitions="2*,4*,1*"> 
 
                            <TextBlock Grid.Column="0" Text="Owner" FontWeight="Bold"/> 
                            <TextBlock Grid.Column="1" Text="Account Number" FontWeight="Bold"/> 
                            <TextBlock Grid.Column="2" Text="Balance" FontWeight="Bold"/> 
 
                        </Grid> 
 
                    </Border> 
 
                    <!-- TABLE --> 
                    <ListBox Name="BankAccountsGrid" Grid.Row="1"> 
 
                        <ListBox.ItemTemplate> 
                            <DataTemplate> 
 
                                <Border BorderBrush="Gray" 
                                        BorderThickness="0,0,0,1" 
                                        Padding="8"> 
 
                                    <Grid ColumnDefinitions="2*,4*,1*"> 
 
                                        <TextBlock Grid.Column="0" Text="{Binding Owner}"/> 
                                        <TextBlock Grid.Column="1" Text="{Binding AccountNumber}"/> 
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Balance}"/> 
 
                                    </Grid>
 
                                </Border> 
 
                            </DataTemplate> 
                        </ListBox.ItemTemplate> 
 
                    </ListBox> 
 
                    <!-- DEPOSIT / WITHDRAW BUTTONS --> 
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Spacing="20" 
                                Margin="0,10,0,0"> 
 
                        <Button Content="Deposit" 
                                Width="120" 
                                Click="DepositBtn_Click"/> 
 
                        <Button Content="Withdraw" 
                                Width="120" 
                                Click="WithdrawBtn_Click"/> 
 
                    </StackPanel> 
 
                </Grid> 
 
            </Grid> 
 
        </Border> 
 
    </Grid> 
 
</Window>